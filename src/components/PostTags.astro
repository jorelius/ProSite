---
interface Props {
  tags: string[];
}

const { tags } = Astro.props;

function kebabCase(str: string): string {
  return str.toLowerCase().replace(/\s+/g, "-");
}
---

<div class="tags">
  <ul class="tags__list">
    {tags.map((tag) => (
      <li class="tags__list-item">
        <a href={`/tag/${kebabCase(tag)}/`} class="tags__list-item-link">
          {tag}
        </a>
      </li>
    ))}
  </ul>
</div>

<style>
  .tags {
    margin-bottom: 13px;
  }

  .tags__list {
    list-style: none;
    margin: 0 -10px;
    padding: 0;
  }

  .tags__list-item {
    display: inline-block;
    margin: 10px 5px;
  }

  .tags__list-item-link {
    display: inline-block;
    height: 35px;
    padding: 0 24px;
    line-height: 35px;
    border: 1px solid #dedede;
    text-decoration: none;
    border-radius: 20px;
    color: #222;
  }

  .tags__list-item-link:hover,
  .tags__list-item-link:focus {
    color: #5D93FF;
  }
</style>
