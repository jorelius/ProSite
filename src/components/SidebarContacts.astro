---
import Icon from "./Icon.astro";
import { AUTHOR, ICONS, getContactHref } from "../consts";

const contacts = AUTHOR.contacts;
---

<div class="contacts">
  <ul class="contacts__list">
    {Object.entries(contacts).map(([name, value]) => {
      const icon = ICONS[name];
      if (!icon) return null;
      return (
        <li class="contacts__list-item">
          <a
            class="contacts__list-item-link"
            href={getContactHref(name, value as string)}
            rel="noopener noreferrer"
            target="_blank"
          >
            <Icon viewBox={icon.viewBox} path={icon.path} />
          </a>
        </li>
      );
    })}
  </ul>
</div>

<style>
  .contacts {
    margin-bottom: 26px;
  }

  .contacts__list {
    display: flex;
    flex-flow: row wrap;
    flex-grow: 0;
    flex-shrink: 0;
    list-style: none;
    padding: 0;
    margin: 10px -3px;
    width: 140px;
  }

  .contacts__list-item {
    padding: 0;
    margin: 4px;
    display: flex;
    align-content: center;
    align-items: center;
    justify-content: center;
    height: 35px;
    width: 35px;
    line-height: 35px;
    border-radius: 50%;
    text-align: center;
    border: 1px solid #e2e2e2;
  }

  .contacts__list-item-link {
    border: 0;
    display: flex;
    color: #222;
    text-decoration: none;
  }

  .contacts__list-item-link:hover,
  .contacts__list-item-link:focus {
    color: #5D93FF;
  }
</style>
